{
  "name": "workout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "zwo-workout-parser": "*"
  },
  "homepage": "https://r-52.github.io/workouts",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gh": "tsc -b && vite build --base=/workouts/",
    "predeploy": "npm run build:gh",
    "deploy": "gh-pages -d dist -t",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:gh": "vite preview --base /workouts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12",
    "zwo-workout-parser": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
